# Generic cache/state
**/Cache/
**/CachedData/
**/Code Cache/
**/GPUCache/
**/Service Worker/
**/Session Storage/
**/Local Storage/
**/logs/
**/logs/**
**/*.log

# VS Code / VSCodium machine state
**/User/workspaceStorage/
**/User/globalStorage/
**/User/History/
**/User/sync/
**/User/CachedProfilesData/

# Browser profiles - do not version
.config/chromium/
.config/google-chrome/
.config/mozilla/

# Credentials / tokens
**/credentials*
**/access_tokens*
**/accounts*
**/Token*
**/tokens*
**/secrets*
**/keyrings/

# KDE/session volatile
**/session/
**/kwallet*
**/recently-used*

# Host-local QT theme state
qt/.config/Kvantum/kvantum.kvconfig

# Host-local GTK/KDE generated theme state
gtk/.config/gtk-3.0/settings.ini
gtk/.config/gtk-4.0/settings.ini
gtk/.config/gtkrc
gtk/.config/gtkrc-2.0
gtk/.config/gtk-3.0/*.lock
gtk/.config/gtk-4.0/*.lock
